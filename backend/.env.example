# Firebase (optional — falls back to mock data)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Gemini API (optional — RAG falls back to rule-based answers)
GEMINI_API_KEY=your-gemini-api-key

# n8n webhook (optional — alerts logged locally if unset)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/hydromind-alerts

# SMTP Email (optional — enables direct email alerts without n8n)
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
ALERT_TO_EMAIL=fallback-recipient@gujarat.gov.in

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
